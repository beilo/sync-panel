{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "允许前端调用 sidecar 与核心 IPC",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/sync-panel-cli",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
